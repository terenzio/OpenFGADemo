              "raw": "{\n  \"type\": \"folder\",\n  \"relation\": \"viewer\",\n  \"user\": \"user:eve\",\n  \"authorization_model_id\": \"{{model_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/stores/{{store_id}}/list-objects",
              "host": ["{{base_url}}"],
              "path": ["stores", "{{store_id}}", "list-objects"]
